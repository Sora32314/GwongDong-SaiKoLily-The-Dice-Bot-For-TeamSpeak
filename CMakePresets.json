{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "core debug",
            "displayName": "Debug Build",
            "description": "Build Core Target With Debug Info",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/Build/Debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_SOURCE_DIR": ".",
                "CMAKE_C_STANDARD": "23",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_CXX_EXTENSIONS": "OFF",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/Build/Debug/bin",
                "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/Build/Debug/lib",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/Build/Debug/lib",


                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            },
            "environment": {
                "CC": "cl.exe",
                "CXX": "cl.exe"
            }
        },
        {
            "name": "core release",
            "displayName": "Release Build",
            "description": "Build Core Target In Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/Build/Release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_SOURCE_DIR": ".",
                "CMAKE_C_STANDARD": "23",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_CXX_EXTENSIONS": "OFF",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                

                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/Build/Release/bin",
                "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/Build/Release/lib",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/Build/Release/lib",


                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            },
            "environment": {
                "CC": "cl.exe",
                "CXX": "cl.exe"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug Build",
            "configurePreset": "core debug",
            "configuration": "Debug",
            "targets":["Plugin_GwongDong", "encapsulation_spdlog", "saiko_lily", "command_core"]
        }
    ]
}